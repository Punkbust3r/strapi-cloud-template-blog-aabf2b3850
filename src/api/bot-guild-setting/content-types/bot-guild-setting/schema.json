{
  "kind": "collectionType",
  "collectionName": "bot_guild_settings",
  "info": {
    "singularName": "bot-guild-setting",
    "pluralName": "bot-guild-settings",
    "displayName": "Bot Guild Setting",
    "description": "Discord bot settings per guild"
  },
