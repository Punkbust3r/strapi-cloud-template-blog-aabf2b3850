    "guildId": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "guildName": {
      "type": "string"
    },
    "language": {
      "type": "string",
      "default": "de"
    },
    "commandPrefix": {
      "type": "string"
    },
    "logChannelId": {
      "type": "string"
    },
    "modLogChannelId": {
      "type": "string"
    },
    "announcementChannelId": {
      "type": "string"
    },
    "serverStatusChannelId": {
      "type": "string"
    },
    "serverStatusMessageId": {
      "type": "string"
    }
  }
}
