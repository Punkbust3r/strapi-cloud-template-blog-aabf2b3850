{
  "kind": "collectionType",
  "collectionName": "linked_game_accounts",
  "info": {
    "singularName": "linked-game-account",
    "pluralName": "linked-game-accounts",
    "displayName": "Linked Game Account",
    "description": "Primary MRP:V identity account used for Discord/FiveM/UCP linkage and join-state decisions"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "discordId": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "username": {
      "type": "string",
      "required": true
    },
    "displayName": {
      "type": "string"
    },
    "discordUsername": {
      "type": "string"
    },
    "discordGlobalName": {
      "type": "string"
    },
    "discordAvatarUrl": {
      "type": "string"
    },
    "primaryIdentifier": {
      "type": "string"
    },
    "gameAccountId": {
      "type": "string"
    },
    "ucpAccountId": {
      "type": "string"
    },
    "accountStatus": {
      "type": "enumeration",
      "enum": [
        "pending_registration",
        "active",
        "blocked",
        "banned",
        "suspended"
      ],
      "default": "pending_registration"
    },
    "requiresOnboarding": {
      "type": "boolean",
      "default": true
    },
    "isBlocked": {
      "type": "boolean",
      "default": false
    },
    "blockedReason": {
      "type": "text"
    },
    "warningCount": {
      "type": "integer",
      "default": 0
    },
    "banReason": {
      "type": "text"
    },
    "banExpiresAt": {
      "type": "datetime"
    },
    "firstSeenAt": {
      "type": "datetime"
    },
    "lastSeenAt": {
      "type": "datetime"
    },
    "firstJoinAt": {
      "type": "datetime"
    },
    "lastJoinAt": {
      "type": "datetime"
    },
    "lastLoginAt": {
      "type": "datetime"
    },
    "consentRecord": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::discord-join-consent-record.discord-join-consent-record"
    },
    "metadata": {
      "type": "json"
    }
  }
}
